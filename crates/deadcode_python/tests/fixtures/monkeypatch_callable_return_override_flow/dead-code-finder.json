{
  "roots": [{ "path": "app", "module": "app" }],
  "entrypoints": ["app/main.py"],
  "includeTests": true,
  "rules": {
    "calls": [
      {
        "receiverType": "pytest.MonkeyPatch",
        "method": "setattr",
        "effect": "replaceCallableReturn",
        "targetArgument": 0,
        "argument": 1
      },
      {
        "receiverType": "pytest.MonkeyPatch",
        "method": "setattr",
        "effect": "replaceCallableReturn",
        "targetArgument": 0,
        "memberArgument": 1,
        "argument": 2
      }
    ]
  }
}
